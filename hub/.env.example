# Hub Veridian — Environment Variables
# Copy to .env.local and fill in real values

# Supabase (self-hosted)
NEXT_PUBLIC_SUPABASE_URL=https://api.app.veridian.site
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Services URLs
NEXT_PUBLIC_TWENTY_URL=https://twenty.app.veridian.site
NEXT_PUBLIC_NOTIFUSE_URL=https://notifuse.app.veridian.site
NEXT_PUBLIC_NOTIFUSE_API_URL=https://notifuse.app.veridian.site
NEXT_PUBLIC_SITE_URL=https://app.veridian.site

# Prospection integration
PROSPECTION_API_URL=http://prospection:3000
PROSPECTION_TENANT_API_SECRET=your-tenant-secret
NEXT_PUBLIC_PROSPECTION_URL=https://prospection.app.veridian.site

# Twenty integration
TWENTY_GRAPHQL_URL=http://twenty-server:3000/graphql
TWENTY_APP_SECRET=your-twenty-secret

# Notifuse integration
NOTIFUSE_API_URL=http://notifuse:8081
NOTIFUSE_SECRET_KEY=your-notifuse-secret

# Trial
NEXT_PUBLIC_TRIAL_PERIOD_DAYS=7

# === Auth.js v5 (P1.4) ===
# Secret généré avec `openssl rand -base64 32`
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://app.veridian.site
AUTH_TRUST_HOST=true

# Google OAuth 2.0 (console.cloud.google.com, projet veridian-preprod)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Prisma — veridian-core-db dédié (P1.0)
# Format : postgresql://veridian:<password>@veridian-core-db:5432/veridian?schema=hub_app
DATABASE_URL=postgresql://veridian:password@veridian-core-db:5432/veridian?schema=hub_app

# Brevo transactional email (pour les codes MFA)
BREVO_API_KEY=
# Fallback SMTP Lark si BREVO_API_KEY absent
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
