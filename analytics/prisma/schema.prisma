// Analytics — Schema Prisma
// Cible : veridian-core-db (Postgres 16 dedie), schema `analytics`
//
// Multitenant des le jour 1 :
//   Tenant -> Membership -> User (N:N via Membership)
//   Tenant -> Site (1:N) -> Pageview, FormSubmission (1:N)
//   Tenant -> GscProperty (1:N, plus tard)
//
// Auth : Auth.js v5 credentials provider (email/password local).
// Pas de dependance au Hub pour l'auth — l'app tourne meme si le Hub est down.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["analytics"]
}

// ============================================================================
// Auth.js core models (conformes @auth/prisma-adapter)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String? // pour credentials provider
  // Nom explicite `platformRole` pour eviter la confusion avec MembershipRole
  // qui est scope tenant (OWNER/ADMIN/MEMBER/VIEWER au niveau d'un tenant).
  // platformRole est scope plateforme : MEMBER = user normal, SUPERADMIN = Robert.
  platformRole  UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]

  @@schema("analytics")
}

// Role plateforme (distinct de MembershipRole qui est scope tenant).
// MEMBER = user normal, SUPERADMIN = Robert qui peut voir tous les tenants
// via /admin et impersonner un tenant via cookie veridian_admin_as_tenant.
enum UserRole {
  MEMBER
  SUPERADMIN

  @@schema("analytics")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("analytics")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("analytics")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("analytics")
}

// ============================================================================
// Multi-tenant core
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  memberships       Membership[]
  sites              Site[]
  pushSubscriptions  PushSubscription[]

  @@schema("analytics")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@schema("analytics")
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@schema("analytics")
}

// ============================================================================
// Sites & traffic (v0 — sera enrichi avec Pageview, FormSubmission plus tard)
// ============================================================================

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  domain    String
  name      String
  siteKey   String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageviews       Pageview[]
  formSubmissions FormSubmission[]
  sipCalls        SipCall[]
  gscDaily        GscDaily[]
  gscProperty     GscProperty?

  @@index([tenantId])
  @@schema("analytics")
}

// ============================================================================
// Tracking events (POC — ingestion cote sites clients)
// ============================================================================

model Pageview {
  id        String   @id @default(cuid())
  siteId    String
  path      String
  referrer  String?
  utmSource String?
  utmMedium String?
  utmTerm   String?
  country   String?
  userAgent String?  @db.Text
  sessionId String?
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@schema("analytics")
}

model FormSubmission {
  id        String   @id @default(cuid())
  siteId    String
  formName  String
  path      String?
  payload   Json
  email     String?
  phone     String?
  utmSource String?
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@schema("analytics")
}

model SipCall {
  id        String    @id @default(cuid())
  siteId    String
  callId    String    @unique
  fromNum   String
  toNum     String
  direction String // inbound | outbound
  status    String // answered | missed | voicemail
  duration  Int       @default(0)
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, startedAt])
  @@schema("analytics")
}

// ============================================================================
// GscDaily — clone 1:1 des dimensions Google Search Console
// ============================================================================
// Chaque row correspond a une ligne de searchAnalytics.query avec tous les
// breakdowns actifs. Le "sheet" compose par (day, query, page, country,
// device, searchType) est unique car GSC n'agrege jamais plus fin.

model GscDaily {
  id          String   @id @default(cuid())
  siteId      String
  day         DateTime @db.Date

  // Dimensions GSC
  query       String
  page        String
  country     String   // code ISO3 GSC (ex: "fra", "usa", "(zz)" si inconnu)
  device      String   // "desktop" | "mobile" | "tablet"
  searchType  String   // "web" | "image" | "video" | "news" | "discover" | "googleNews"

  // Metriques
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, day, query, page, country, device, searchType], map: "GscDaily_unique_row")
  @@index([siteId, day])
  @@index([siteId, day, searchType])
  @@index([siteId, query])
  @@index([siteId, page])
  @@schema("analytics")
}

// ============================================================================
// GSC Property — lien entre un Site Veridian et une propriete Google Search Console
// ============================================================================
// Pour le POC : on utilise un refresh_token Google global (env GSC_REFRESH_TOKEN)
// qui appartient au compte de Robert (owner sur toutes les proprietes GSC clients).
// Quand un client voudra connecter SON Google, on ajoutera un champ refreshToken
// chiffre ici et on fera un flow OAuth per-tenant.

model GscProperty {
  id         String   @id @default(cuid())
  siteId     String   @unique
  // Format GSC : "sc-domain:veridian.site" OU "https://www.veridian.site/"
  propertyUrl String
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@schema("analytics")
}

// ============================================================================
// Push Subscriptions — Web Push notifications (PWA)
// ============================================================================
// Chaque browser qui s'abonne au push cree une PushSubscription liee au tenant.
// Le champ endpoint est unique (un browser = un endpoint).
// userId et siteId sont optionnels : on peut notifier un tenant entier.

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  siteId    String?
  tenantId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  // Metadata device collectee au moment du subscribe — permet de croiser
  // avec les appels telephoniques (meme horaire = meme lead probable)
  // et de segmenter les abonnes par plateforme/langue.
  userAgent   String?  @db.Text   // ex: "Mozilla/5.0 (iPhone; CPU iPhone OS 18_0..."
  language    String?              // ex: "fr-FR"
  screenSize  String?              // ex: "390x844"
  platform    String?              // ex: "iOS", "Android", "Desktop"
  installPage String?              // page depuis laquelle l'install s'est faite (ex: "/contact")
  ip          String?              // IP de la requete au moment du subscribe

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@schema("analytics")
}
