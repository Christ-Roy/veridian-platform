# Analytics — Env vars exemple
# Copier en .env.local pour dev

# Node
NODE_ENV=development
PORT=3000

# Auth.js
AUTH_SECRET=           # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Prisma (veridian-core-db)
DATABASE_URL=postgresql://veridian:password@localhost:5432/veridian?schema=analytics
