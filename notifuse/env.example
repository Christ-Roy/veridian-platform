# Variables Veridian-specific en plus des variables upstream Notifuse
# Voir env.example dans le repo Christ-Roy/notifuse-veridian pour les vars
# upstream (DB_*, SECRET_KEY, ROOT_EMAIL, API_ENDPOINT, SMTP_*, etc.)

# === HMAC pilotage Hub → Notifuse ===
# Secret partage entre Hub et Notifuse pour signer les requetes /api/tenants/*
# Genere : openssl rand -hex 32
HUB_API_SECRET=

# === Webhooks sortants Notifuse → Hub ===
# URL Hub qui recoit les events (tenant.provisioned, email.sent, etc.)
HUB_WEBHOOK_URL=https://app.veridian.site/api/webhooks/notifuse
# Secret pour signer les events sortants (different de HUB_API_SECRET)
HUB_WEBHOOK_SECRET=

# === Plan par defaut ===
# Plan applique au provisioning si non precise dans le body
# Valeurs : free, pro, business
VERIDIAN_DEFAULT_PLAN=free

# === Quotas par plan (override possible) ===
# Format : <plan>:<emails_per_month>
# Defaut hardcode dans internal/domain/veridian.go : free=500, pro=10000, business=50000
# VERIDIAN_QUOTA_OVERRIDE=free:1000,pro:20000
