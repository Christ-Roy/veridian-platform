// Grafana Alloy config — generated by deploy-alloy.sh, do not edit on the VPS.
// Source of truth: veridian-platform-infra/grafana/alloy/config.alloy.tmpl
//
// Placeholders rendered at deploy time:
//   {{HOSTNAME}}   = le hostname du VPS (mail, vps, dev-server-1)
//   {{ENV}}        = prod / dev / local
//
// Credentials lus depuis /etc/alloy/gcloud.env (mode 0600, owner alloy)
//   GCLOUD_TOKEN (commun)
//   GCLOUD_LOKI_URL  + GCLOUD_LOKI_USER  (tenant Loki)
//   GCLOUD_MIMIR_URL + GCLOUD_MIMIR_USER (tenant Mimir)
//   GCLOUD_TEMPO_URL + GCLOUD_TEMPO_USER (tenant Tempo)
//   GCLOUD_OTLP_URL  + GCLOUD_OTLP_USER  (= stack ID, pour OTLP gateway unifié)

// =========================================================================
// LOGS Docker → Loki (push natif Loki, pas OTLP — plus efficace pour Loki)
// =========================================================================

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = []

  // Strip le slash initial du container name (Docker préfixe avec /)
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  // Label compose_project pour grouper par stack Dokploy
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "compose_project"
  }

  // Label image pour identifier les containers Veridian
  rule {
    source_labels = ["__meta_docker_container_label_org_opencontainers_image_title"]
    target_label  = "image_title"
  }
}

loki.source.docker "containers" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.containers.targets
  labels        = {
    host = "{{HOSTNAME}}",
    env  = "{{ENV}}",
  }
  relabel_rules = discovery.relabel.containers.rules
  forward_to    = [loki.write.gcloud.receiver]
}

loki.write "gcloud" {
  endpoint {
    url = sys.env("GCLOUD_LOKI_URL") + "/loki/api/v1/push"

    basic_auth {
      username = sys.env("GCLOUD_LOKI_USER")
      password = sys.env("GCLOUD_TOKEN")
    }
  }
}

// =========================================================================
// HOST METRICS (CPU, RAM, disk, network) → Mimir
// =========================================================================

prometheus.exporter.unix "host" {
  include_exporter_metrics = false
  disable_collectors       = ["ipvs", "infiniband", "nfs", "nfsd", "xfs", "btrfs"]
}

prometheus.scrape "host" {
  targets         = prometheus.exporter.unix.host.targets
  forward_to      = [prometheus.relabel.host.receiver]
  scrape_interval = "60s"
  job_name        = "node"
}

prometheus.relabel "host" {
  rule {
    target_label = "host"
    replacement  = "{{HOSTNAME}}"
  }
  rule {
    target_label = "env"
    replacement  = "{{ENV}}"
  }
  forward_to = [prometheus.remote_write.gcloud.receiver]
}

// =========================================================================
// DOCKER METRICS (per container) → Mimir
// Whitelist agressive pour rester sous 10k séries free tier.
// =========================================================================

prometheus.exporter.cadvisor "docker" {
  docker_host         = "unix:///var/run/docker.sock"
  storage_duration    = "5m"
  enabled_metrics     = ["cpu", "memory", "network", "diskIO"]
}

prometheus.scrape "docker" {
  targets         = prometheus.exporter.cadvisor.docker.targets
  forward_to      = [prometheus.relabel.docker.receiver]
  scrape_interval = "60s"
  job_name        = "cadvisor"
}

prometheus.relabel "docker" {
  // Garde uniquement les metrics utiles, drop le reste
  rule {
    source_labels = ["__name__"]
    regex         = "container_(cpu_usage_seconds_total|memory_working_set_bytes|memory_usage_bytes|network_receive_bytes_total|network_transmit_bytes_total|fs_reads_bytes_total|fs_writes_bytes_total|last_seen)"
    action        = "keep"
  }

  // Drop les labels haute cardinalité qui font exploser les séries
  rule {
    action = "labeldrop"
    regex  = "id|container_label_.*"
  }

  rule {
    target_label = "host"
    replacement  = "{{HOSTNAME}}"
  }
  rule {
    target_label = "env"
    replacement  = "{{ENV}}"
  }

  forward_to = [prometheus.remote_write.gcloud.receiver]
}

prometheus.remote_write "gcloud" {
  endpoint {
    url = sys.env("GCLOUD_MIMIR_URL")

    basic_auth {
      username = sys.env("GCLOUD_MIMIR_USER")
      password = sys.env("GCLOUD_TOKEN")
    }
  }
}

// =========================================================================
// OTLP RECEIVER (pour traces Traefik) → Tempo
// Traefik push ses traces ici via gRPC sur :4317, Alloy forward vers Tempo.
// =========================================================================

otelcol.receiver.otlp "traefik" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.processor.batch.default.input]
  }
}

otelcol.processor.batch "default" {
  output {
    traces = [otelcol.exporter.otlphttp.gcloud.input]
  }
}

otelcol.exporter.otlphttp "gcloud" {
  client {
    endpoint = sys.env("GCLOUD_OTLP_URL")
    auth     = otelcol.auth.basic.gcloud.handler
  }
}

otelcol.auth.basic "gcloud" {
  username = sys.env("GCLOUD_TEMPO_USER")
  password = sys.env("GCLOUD_TOKEN")
}
