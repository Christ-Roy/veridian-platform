// Grafana Alloy config — generated by deploy-alloy.sh, do not edit on the VPS.
// Source of truth: veridian-platform-infra/grafana/alloy/config.alloy.tmpl
//
// Placeholders rendered at deploy time:
//   {{HOSTNAME}}   = le hostname du VPS (mail, vps, dev-server-1)
//   {{ENV}}        = prod / dev / local
//
// Credentials lus depuis /etc/alloy/gcloud.env (mode 0600, owner alloy)

// =========================================================================
// LOGS Docker → Loki (avec parsing JSON Traefik et filtres anti-quota)
// =========================================================================

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = []

  // Strip le slash initial du container name (Docker préfixe avec /)
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  // Label compose_project pour grouper par stack Dokploy
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "compose_project"
  }

  // Label image pour identifier les containers Veridian
  rule {
    source_labels = ["__meta_docker_container_label_org_opencontainers_image_title"]
    target_label  = "image_title"
  }
}

loki.source.docker "containers" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.containers.targets
  labels        = {
    host   = "{{HOSTNAME}}",
    env    = "{{ENV}}",
    source = "docker",
  }
  relabel_rules = discovery.relabel.containers.rules
  forward_to    = [loki.process.docker_router.receiver]
}

// -------------------------------------------------------------------------
// Pipeline de traitement des logs Docker :
//   1. Si container == dokploy-traefik : parse le JSON accessLog
//   2. Détection du level (info/warn/error/fatal) via regex
//   3. Filtres ENV-dépendants : prod = strict, dev = laisse tout passer
//   4. Metric counter dropped_logs_total pour mesurer l'efficacité
// -------------------------------------------------------------------------

loki.process "docker_router" {
  // ----- Détection du niveau de log (commun à tous containers) -----
  stage.regex {
    expression = "(?i)\\b(?P<level>fatal|error|warn(ing)?|info|debug|trace)\\b"
  }

  // Si on a trouvé un level, on l'ajoute en label (low cardinality, 6 valeurs max)
  stage.labels {
    values = { level = "" }
  }

  // ----- Si dokploy-traefik : extrait status + method + route depuis JSON -----
  stage.match {
    selector = "{container=\"dokploy-traefik\"}"

    stage.json {
      expressions = {
        status = "DownstreamStatus",
        method = "RequestMethod",
        route  = "RouterName",
        path   = "RequestPath",
      }
    }
    stage.labels {
      values = { status = "", method = "", route = "" }
    }
  }

  // ----- Metric : compte les logs en INFO/DEBUG/TRACE avant filtrage -----
  stage.metrics {
    metric.counter {
      name        = "alloy_logs_processed_total"
      description = "Logs traités par Alloy avant filtrage, par level/container."
      action      = "inc"
      max_idle_duration = "5m"
    }
  }

  forward_to = [loki.process.prod_filter.receiver]
}

// -------------------------------------------------------------------------
// FILTRES PROD ONLY — drop le bruit pour rester sous le quota
// En dev on laisse tout passer (visibilité maximale).
// -------------------------------------------------------------------------

loki.process "prod_filter" {
{{PROD_FILTERS}}

  forward_to = [loki.write.gcloud.receiver]
}

loki.write "gcloud" {
  endpoint {
    url = sys.env("GCLOUD_LOKI_URL") + "/loki/api/v1/push"

    basic_auth {
      username = sys.env("GCLOUD_LOKI_USER")
      password = sys.env("GCLOUD_TOKEN")
    }
  }
}

// =========================================================================
// LOGS systemd journald → Loki (auth, sshd, sudo, fail2ban, kernel)
// =========================================================================

// Pas de `matches` (les filtres OR ne sont pas possibles dans la syntaxe systemd
// journal). On lit tout le journal du host et on filtre/labelise dans loki.process.

loki.relabel "journal_unit" {
  forward_to = []
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "priority"
  }
  rule {
    source_labels = ["__journal_syslog_identifier"]
    target_label  = "ident"
  }
}

loki.source.journal "system" {
  forward_to    = [loki.process.journal_filter.receiver]
  relabel_rules = loki.relabel.journal_unit.rules
  labels        = {
    host   = "{{HOSTNAME}}",
    env    = "{{ENV}}",
    source = "journald",
  }
}

loki.process "journal_filter" {
  // Drop journal noise : audit messages benign, kernel cgroup events
  stage.drop {
    expression          = `audit(_log)?:|cgroup: Removed`
    drop_counter_reason = "journald_audit_noise"
  }

  forward_to = [loki.write.gcloud.receiver]
}

// =========================================================================
// HOST METRICS (CPU, RAM, disk, network) → Mimir
// =========================================================================

prometheus.exporter.unix "host" {
  include_exporter_metrics = false
  disable_collectors       = ["ipvs", "infiniband", "nfs", "nfsd", "xfs", "btrfs"]
}

prometheus.scrape "host" {
  targets         = prometheus.exporter.unix.host.targets
  forward_to      = [prometheus.relabel.host.receiver]
  scrape_interval = "60s"
  job_name        = "node"
}

prometheus.relabel "host" {
  rule {
    target_label = "host"
    replacement  = "{{HOSTNAME}}"
  }
  rule {
    target_label = "env"
    replacement  = "{{ENV}}"
  }
  forward_to = [prometheus.remote_write.gcloud.receiver]
}

// =========================================================================
// DOCKER METRICS (per container) → Mimir
// Whitelist agressive pour rester sous 10k séries free tier.
// =========================================================================

prometheus.exporter.cadvisor "docker" {
  docker_host         = "unix:///var/run/docker.sock"
  storage_duration    = "5m"
  enabled_metrics     = ["cpu", "memory", "network", "diskIO"]
}

prometheus.scrape "docker" {
  targets         = prometheus.exporter.cadvisor.docker.targets
  forward_to      = [prometheus.relabel.docker.receiver]
  scrape_interval = "60s"
  job_name        = "cadvisor"
}

prometheus.relabel "docker" {
  rule {
    source_labels = ["__name__"]
    regex         = "container_(cpu_usage_seconds_total|memory_working_set_bytes|memory_usage_bytes|network_receive_bytes_total|network_transmit_bytes_total|fs_reads_bytes_total|fs_writes_bytes_total|last_seen)"
    action        = "keep"
  }

  rule {
    action = "labeldrop"
    regex  = "id|container_label_.*"
  }

  rule {
    target_label = "host"
    replacement  = "{{HOSTNAME}}"
  }
  rule {
    target_label = "env"
    replacement  = "{{ENV}}"
  }

  forward_to = [prometheus.remote_write.gcloud.receiver]
}

// Métriques Alloy lui-même → utile pour le dashboard "obs health"
prometheus.exporter.self "alloy" {}

prometheus.scrape "alloy" {
  targets         = prometheus.exporter.self.alloy.targets
  forward_to      = [prometheus.relabel.host.receiver]
  scrape_interval = "60s"
  job_name        = "alloy"
}

prometheus.remote_write "gcloud" {
  endpoint {
    url = sys.env("GCLOUD_MIMIR_URL")

    basic_auth {
      username = sys.env("GCLOUD_MIMIR_USER")
      password = sys.env("GCLOUD_TOKEN")
    }
  }
}

// =========================================================================
// OTLP RECEIVER (pour traces Traefik) → Tempo
// =========================================================================

otelcol.receiver.otlp "traefik" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.processor.batch.default.input]
  }
}

otelcol.processor.batch "default" {
  output {
    traces = [otelcol.exporter.otlphttp.gcloud.input]
  }
}

otelcol.exporter.otlphttp "gcloud" {
  client {
    endpoint = sys.env("GCLOUD_OTLP_URL")
    auth     = otelcol.auth.basic.gcloud.handler
  }
}

otelcol.auth.basic "gcloud" {
  username = sys.env("GCLOUD_TEMPO_USER")
  password = sys.env("GCLOUD_TOKEN")
}
