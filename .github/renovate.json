{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Paris)"
  ],
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patches Trivy-clean (Phase B sprint GitOps 2026-05-13)",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchFileNames": ["prospection/**", "infra/services/prospection/**"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Auto-merge digest pins (image SHA bumps) - reservoir d'efforts CVE upstream",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "matchFileNames": ["infra/services/prospection/**"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "1 days"
    },
    {
      "description": "Majors restent manuels - review humaine obligatoire",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "renovate", "major-bump"]
    },
    {
      "description": "Next.js / Auth.js / React - migration guides necessaires sur minor+major",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "next-auth",
        "@auth/core",
        "@auth/prisma-adapter"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["dependencies", "renovate", "framework-bump"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "automerge": false
  },
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard - Veridian Platform"
}
