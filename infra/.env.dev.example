############################################################################
# GLOBAL SAAS PLATFORM - Development Environment
############################################################################
# Variables de base UNIQUEMENT
# Les configurations détaillées sont dans docker-compose.dev.yml
#
# USAGE:
#   1. cp .env.dev.example .env
#   2. Ajuster si nécessaire
#   3. docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
############################################################################

############################################################################
# BASE CONFIGURATION
############################################################################
PROTOCOL=http
DOMAIN=lvh.me
PORT=":8000"
TZ=Europe/Paris

# URLs de base (construites automatiquement)
BASE_URL=${PROTOCOL}://${DOMAIN}${PORT}
API_URL=${PROTOCOL}://api.${DOMAIN}${PORT}
STUDIO_URL=${PROTOCOL}://studio.${DOMAIN}${PORT}
TWENTY_URL=${PROTOCOL}://twenty.${DOMAIN}${PORT}
NOTIFUSE_URL=${PROTOCOL}://notifuse.${DOMAIN}${PORT}

############################################################################
# SECRETS - Development (OK pour dev, à changer en prod)
############################################################################
POSTGRES_PASSWORD=dev_postgres_password
JWT_SECRET=dev-jwt-secret-min-32-characters-long
JWT_EXPIRY=3600
SECRET_KEY_BASE=dev-secret-key-base-min-32-characters
PG_META_CRYPTO_KEY=dev-pg-meta-crypto-key-min-32-chars
VAULT_ENC_KEY=dev-vault-enc-key-min-32-characters

NOTIFUSE_SECRET_KEY=dev-notifuse-secret-key-min-32-chars
TWENTY_APP_SECRET=dev-twenty-secret-min-32-characters

############################################################################
# SUPABASE KEYS - Development (clés publiques, OK pour dev)
############################################################################
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=supabase

############################################################################
# DATABASE CONFIG
############################################################################
POSTGRES_HOST=supabase-db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############################################################################
# SUPABASE URLs (utilise les variables de base)
############################################################################
SUPABASE_PUBLIC_URL=${API_URL}
API_EXTERNAL_URL=${API_URL}
SITE_URL=${BASE_URL}

############################################################################
# KONG
############################################################################
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############################################################################
# AUTH CONFIG
############################################################################
ADDITIONAL_REDIRECT_URLS=${BASE_URL}/auth/**,${STUDIO_URL},${API_URL},${BASE_URL},${NOTIFUSE_URL},${TWENTY_URL},http://localhost:3000
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_AUTOCONFIRM=false  # Force email verification in dev
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true

############################################################################
# STUDIO
############################################################################
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

############################################################################
# API CONFIG
############################################################################
PGRST_DB_SCHEMAS=public,storage,graphql_public
FUNCTIONS_VERIFY_JWT=false

############################################################################
# POOLER
############################################################################
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=tenant_dev
POOLER_DB_POOL_SIZE=5

############################################################################
# STORAGE
############################################################################
IMGPROXY_ENABLE_WEBP_DETECTION=true

############################################################################
# TWENTY CRM - Config
############################################################################
TWENTY_SERVER_URL=${TWENTY_URL}
TWENTY_IS_MULTIWORKSPACE_ENABLED=true
TWENTY_IS_BILLING_ENABLED=false
TWENTY_IS_EMAIL_VERIFICATION_REQUIRED=false

# Database direct connection (server-side only)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@supabase-db:${POSTGRES_PORT}/${POSTGRES_DB}

############################################################################
# DOCKER
############################################################################
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############################################################################
# DASHBOARD - URLs spécifiques pour Next.js
############################################################################

# Environment
NODE_ENV=development

# Database connection (from container, use service name)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@supabase-db:${POSTGRES_PORT}/${POSTGRES_DB}

# Site
NEXT_PUBLIC_SITE_URL=${BASE_URL}

# Supabase
NEXT_PUBLIC_SUPABASE_URL=${API_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# Twenty CRM
NEXT_PUBLIC_TWENTY_URL=${TWENTY_URL}
TWENTY_GRAPHQL_URL=${TWENTY_URL}/graphql
TWENTY_METADATA_URL=${TWENTY_URL}/metadata
TWENTY_FRONTEND_URL=${TWENTY_URL}

# Notifuse
NOTIFUSE_API_ENDPOINT=${NOTIFUSE_URL}
NEXT_PUBLIC_NOTIFUSE_URL=${NOTIFUSE_URL}
NEXT_PUBLIC_NOTIFUSE_API_URL=${NOTIFUSE_URL}/api/v1
NOTIFUSE_API_URL=${NOTIFUSE_URL}
NOTIFUSE_ROOT_EMAIL=admin@localhost

############################################################################
# STRIPE - Development (test keys)
############################################################################
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_DEV_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_DEV_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_DEV_WEBHOOK_SECRET_HERE

# Production keys (vides en dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_LIVE=

############################################################################
# GITHUB OAUTH - Optionnel (pour authentification GitHub)
############################################################################
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_AUTH_EXTERNAL_GITHUB_REDIRECT_URI=${API_URL}/auth/v1/callback

############################################################################
# SMTP - Mailpit (Dev Email Testing)
############################################################################
# Mailpit intercepte tous les emails en dev
# Interface web: http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@localhost
SMTP_SENDER_NAME=Dev Platform
EMAIL_DRIVER=smtp

############################################################################
# MAILER - Supabase Auth Email Configuration
############################################################################
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
MAILER_EXTERNAL_HOSTS=api.${DOMAIN}${PORT}

############################################################################
# OPENAI (optionnel)
############################################################################
OPENAI_API_KEY=

############################################################################
# GITHUB CONTAINER REGISTRY (GHCR) - Configuration
############################################################################
# ℹ️  Les credentials GitHub sont récupérés automatiquement via 'gh' CLI
# ℹ️  Pas besoin de configurer manuellement (GITHUB_TOKEN, GITHUB_REGISTRY_OWNER)
# ℹ️  Assurez-vous d'être authentifié : gh auth login
# ℹ️  Permissions requises : packages:read, packages:write
