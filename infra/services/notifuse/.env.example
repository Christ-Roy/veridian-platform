# Notifuse — variables d'env requises par la stack Dokploy
# Toutes les valeurs sont gérées dans Dokploy UI → Stack notifuse-prod → Environment.
# Ce fichier liste les noms attendus pour audit/onboarding (PAS DE SECRETS COMMITTÉS).

# --- Image / déploiement ---
NOTIFUSE_IMAGE_TAG=saas-v1.0.3
# Manifest digest (récupéré via docker inspect <image> --format '{{index .RepoDigests 0}}')
# Pas le .Image (= image ID local, différent du manifest digest publié sur le registry)
NOTIFUSE_IMAGE_DIGEST=b07226febf9ea3d4f724f120919d18edf95cbe02dc94d7732c01b5ba5d425adc
NOTIFUSE_DB_IMAGE_DIGEST=ff4ccc02b97e0ebb6b328ef9ff92522f95586f83be6801896b615088defc8ad2
DEPLOY_ENV=prod              # prod | green
NOTIFUSE_HOST=notifuse.app.veridian.site
DOMAIN=app.veridian.site

# --- DB ---
POSTGRES_PASSWORD=

# --- Notifuse core ---
NOTIFUSE_SECRET_KEY=
NOTIFUSE_ROOT_EMAIL=

# --- SMTP (Brevo) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=

# --- Hub integration (fork Veridian) ---
NOTIFUSE_HUB_API_SECRET=
NOTIFUSE_HUB_WEBHOOK_URL=
NOTIFUSE_HUB_WEBHOOK_SECRET=
