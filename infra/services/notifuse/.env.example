# Notifuse — variables d'env requises par la stack Dokploy
# Toutes les valeurs sont gérées dans Dokploy UI → Stack notifuse-prod → Environment.
# Ce fichier liste les noms attendus pour audit/onboarding (PAS DE SECRETS COMMITTÉS).

# --- Image / déploiement ---
NOTIFUSE_IMAGE_TAG=saas-v1.0.3
NOTIFUSE_IMAGE_DIGEST=d0975ef7850483808097ecbbd7278b2cb0657a8df87bc97b3e67d9aa0868143b
NOTIFUSE_DB_IMAGE_DIGEST=aa3668fcbcb5ded731b7d5c27065a4edf545debb7f27bf514c709b1b4e032352
DEPLOY_ENV=prod              # prod | green
NOTIFUSE_HOST=notifuse.app.veridian.site
DOMAIN=app.veridian.site

# --- DB ---
POSTGRES_PASSWORD=

# --- Notifuse core ---
NOTIFUSE_SECRET_KEY=
NOTIFUSE_ROOT_EMAIL=

# --- SMTP (Brevo) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=

# --- Hub integration (fork Veridian) ---
NOTIFUSE_HUB_API_SECRET=
NOTIFUSE_HUB_WEBHOOK_URL=
NOTIFUSE_HUB_WEBHOOK_SECRET=
