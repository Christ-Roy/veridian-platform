# Hub — variables d'env requises par la stack Dokploy
# Toutes les valeurs sont gérées dans Dokploy UI → Stack hub → Environment.
# Ce fichier liste les noms attendus pour audit/onboarding (PAS DE SECRETS COMMITTÉS).

# --- Image / déploiement ---
HUB_IMAGE_TAG=latest
HUB_IMAGE_DIGEST=1406f2c1c0c09c4e70933af93af6fc832a41966e83ffb19bb9ca603438a6ce68
DEPLOY_ENV=prod          # prod | green
HUB_HOST=app.veridian.site

# --- Auth.js v5 ---
HUB_AUTH_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- DB ---
VERIDIAN_CORE_DB_PASSWORD=

# --- Stripe live ---
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# --- Notifuse (fork) ---
NOTIFUSE_SECRET_KEY=
NOTIFUSE_ROOT_EMAIL=
NOTIFUSE_HUB_API_SECRET=
NOTIFUSE_HUB_WEBHOOK_SECRET=

# --- Twenty ---
TWENTY_APP_SECRET=

# --- Prospection ---
PROSPECTION_TENANT_API_SECRET=

# --- Brevo / Supabase / GTM ---
BREVO_API_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GTM_ID_APP_VERIDIAN=

# --- Misc ---
CRON_SECRET=
