# === CMS Veridian — variables d'environnement ===
# Copie ce fichier en .env et renseigne les valeurs.
# Le .env est gitignored (ne JAMAIS committer).

# === Database ===
# Source unique : POSTGRES_PASSWORD. DATABASE_URL est construit dans docker-compose
# via interpolation (postgresql://user:password@cms-postgres:5432/db).
POSTGRES_DB=veridian_cms
POSTGRES_USER=cms
POSTGRES_PASSWORD=changeme-32-chars-min

# Pour dev local sans docker-compose, set DATABASE_URL directement :
# DATABASE_URL=postgresql://cms:password@127.0.0.1:5432/veridian_cms

# === Payload ===
# 64 chars hex : openssl rand -hex 32
PAYLOAD_SECRET=changeme-64-hex-chars

# URL publique de cette instance CMS (ex : https://cms.veridian.site).
# OBLIGATOIRE en NODE_ENV=production (sinon throw au boot).
SERVER_URL=https://cms.veridian.site

# === CORS ===
# Liste comma-separated des origines autorisées (sites clients + admin externes).
# Vide = '*' (acceptable car API key required pour endpoints sensibles).
# CORS_ORIGINS=https://morel-volailles.fr,https://template-artisan.veridian.site

# === SMTP (Brevo recommandé) ===
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@veridian.site

# === Auto-rebuild sites clients (CF Pages via GH Actions workflow_dispatch) ===
# Le hook triggerSiteRebuild lit cfPagesProject sur le tenant pour savoir quel site rebuild.
GITHUB_TOKEN=
GITHUB_REPO=Christ-Roy/veridian-platform
GITHUB_WORKFLOW=sites-deploy.yml

# === Image deploy (CI déclare au moment du up) ===
# IMAGE_TAG=latest

# === Telemetry ===
NEXT_TELEMETRY_DISABLED=1
