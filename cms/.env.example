# === CMS Veridian — variables d'environnement ===
# Copie ce fichier en .env (prod) ou .env.development (dev local).
# Les .env* sont gitignored (ne JAMAIS committer de secrets).

# === Database ===
# Source unique : POSTGRES_PASSWORD. DATABASE_URL est construit dans docker-compose
# via interpolation (postgresql://user:password@cms-postgres:5432/db).
POSTGRES_DB=veridian_cms
POSTGRES_USER=cms
POSTGRES_PASSWORD=changeme-32-chars-min

# Pour dev local sans docker-compose, set DATABASE_URL directement :
# DATABASE_URL=postgresql://cms:password@127.0.0.1:5432/veridian_cms

# === Payload ===
# 64 chars hex : openssl rand -hex 32
PAYLOAD_SECRET=changeme-64-hex-chars

# URL publique de cette instance CMS (ex : https://cms.veridian.site).
# OBLIGATOIRE en NODE_ENV=production (sinon throw au boot).
SERVER_URL=https://cms.veridian.site

# === CORS / CSRF ===
# Liste comma-separated des origines autorisées (admin + sites tenants).
# Indispensable cross-domain (Live Preview cross-subdomain).
# En dev local : http://localhost:3001,http://localhost:4001
CORS_ORIGINS=https://cms.veridian.site,https://avse-monetique.veridian.site
CSRF_ORIGINS=https://cms.veridian.site,https://avse-monetique.veridian.site

# === Live Preview — override des URLs des sites tenants ===
# Optionnel. En prod, on utilise tenant.siteUrl (ex: https://avse-monetique.veridian.site)
# qui pointe vers le site CF Pages prod. Le site embarque le SDK @payloadcms/live-preview
# avec NEXT_PUBLIC_CMS_API_URL=https://cms.veridian.site (baké au build).
#
# En DEV (SERVER_URL=https://cms.dev.veridian.site), la preview ne marche QUE si
# l'iframe pointe vers une version du site rebuilt avec
# NEXT_PUBLIC_CMS_API_URL=https://cms.dev.veridian.site (le SDK fait un strict
# event.origin === serverURL). Sinon le site prod ignore les messages venant
# de cms.dev → preview blanche.
#
# Pour bosser sur l'inline editor avec un site dev :
#   PREVIEW_SITE_URL_MAP={"avse":"https://avse.dev.veridian.site","demo":"https://demo.dev.veridian.site"}
# Ou catch-all (utile pour un seul site dev en test) :
#   PREVIEW_SITE_BASE_OVERRIDE=https://avse.dev.veridian.site
# Laisser vide en prod.
PREVIEW_SITE_URL_MAP=
PREVIEW_SITE_BASE_OVERRIDE=

# === Cookie d'auth (Live Preview cross-subdomain) ===
# PROD : Domain=.veridian.site + SameSite=None + Secure=true (HTTPS)
# DEV LOCAL HTTP : pas de Domain (ou .localhost), SameSite=Lax, Secure=false
AUTH_COOKIE_DOMAIN=.veridian.site
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_SECURE=true

# === SMTP (Brevo recommandé) ===
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@veridian.site

# === Auto-rebuild sites clients (CF Pages via GH Actions workflow_dispatch) ===
# Le hook triggerSiteRebuild lit cfPagesProject sur le tenant pour savoir quel site rebuild.
GITHUB_TOKEN=
GITHUB_REPO=Christ-Roy/veridian-platform
GITHUB_WORKFLOW=sites-deploy.yml

# === Image deploy (CI déclare au moment du up) ===
# IMAGE_TAG=latest

# === Telemetry ===
NEXT_TELEMETRY_DISABLED=1
